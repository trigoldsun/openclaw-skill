  "key_learnings": {
    "environment_setup": [
      "AppID 是小程序唯一标识（类似身份证）",
      "需注册微信开发者账号获取 AppID",
      "下载官方开发者工具支持多平台",
      "使用空目录创建新项目",
      "无需云服务也可完成基础开发"
    ],
    "core_files": [
      "四大文件类型：.json / .wxml / .wxss / .js",
      "JSON 扮演静态配置角色（非编程语言）",
      "WXML 类似 HTML 但使用不同标签",
      "WXSS 新增 rpx 响应式单位",
      "JS 处理业务逻辑和 API 调用"
    ],
    "configuration": [
      "app.json - 全局配置（页面路径、窗口表现）",
      "project.config.json - 工具个性化配置",
      "page.json - 页面级独立配置",
      "不支持 JSON 注释语法",
      "只能使用双引号的键名"
    ],
    "template_syntax": [
      "数据绑定用 {{variable}} 表达式",
      "条件渲染用 wx:if / wx:elif / wx:else",
      "列表渲染用 wx:for 配合 key",
      "事件绑定用 bindtap / catchtap",
      "组件内置 view / text / button 等"
    ],
    "styling": [
      "rpx 自动适配不同屏幕宽度",
      "仅部分 CSS 选择器受支持",
      "全局 app.wxss + 局部 page.wxss",
      "Flexbox 布局完全可用",
      "不支持通配符和复杂组合器"
    ],
    "development_workflow": [
      "开发者工具实时编译预览",
      "扫码方式真机调试",
      "下拉刷新查看错误日志",
      "版本管理通过控制台上传",
      "审核发布需准备测试素材"
    ]
  },
  
  "technical_specifications": {
    "file_extensions": {
      ".json": "静态配置文件（app.json / project.config.json）",
      ".wxml": "视图模板语言（类似 HTML 标记）",
      ".wxss": "样式表（支持 CSS 子集 + rpx 单位）",
      ".js": "脚本逻辑（MVVM 模式 + API 调用）"
    },
    "responsive_units": {
      "rpx": "响应式像素（屏幕宽 750rpx 标准）",
      "px": "固定像素（用于特定场景）"
    },
    "component_categories": {
      "基础组件": "view / text / image / button / input / switch",
      "表单组件": "form / checkbox / radio / slider / picker",
      "导航组件": "navigator / open-type buttons",
      "媒体组件": "video / audio / map / canvas"
    },
    "lifecycle_hooks": [
      "onLoad() - 页面加载",
      "onShow() - 页面显示",
      "onHide() - 页面隐藏",
      "onUnload() - 页面卸载",
      "onPullDownRefresh() - 下拉刷新",
      "onReachBottom() - 触底触发"
    ]
  },
  
